# 复制本文件为 .env 并填入真实值。.env 不会被提交到版本库。
# 程序启动时会自动加载同目录下的 .env（见 cmd/claw/main.go）。
# 未在 .env 中设置的变量，会回退使用系统环境变量。

# ===== 智谱 / DeepSeek（必填）=====
# 智谱开放平台或 DeepSeek 的 API Key
ZHIPU_API_KEY=

# 使用的模型名称
ZHIPU_MODEL=deepseek-v4-flash

# ===== 飞书机器人（必填）=====
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ===== 飞书事件订阅（可选，按需配置）=====
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFY_TOKEN=

# ===== HTTP 服务（可选）=====
# 监听端口（纯数字，无需冒号前缀）
PORT=48080
